# Family OS — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# Notion Integration Token
# Get this from: https://www.notion.so/my-integrations
# The integration needs access to: Family Tasks, Projects, Family Calendar, Meal Planner databases
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database IDs (pre-filled — only change if you recreate these databases)
NOTION_FAMILY_TASKS_DB=395f395ac3de4ddaa8e86518e3c0377a
NOTION_PROJECTS_DB=c5ca349eadad491c8a3f16e2b82b506a
NOTION_FAMILY_CALENDAR_DB=       # To be added when Story 04 ships
NOTION_MEAL_PLANNER_DB=3332cb98-3974-808d-b6dc-000b742030b8

# Digest output page parent (the Family OS hub page)
NOTION_HUB_PAGE_ID=34a2cb98-3974-8170-9c3e-c3746f6e9b8f
